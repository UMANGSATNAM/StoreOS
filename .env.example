# ─── Local Development (SQLite) ───
DATABASE_URL=file:./db/custom.db

# ─── Production / Railway (PostgreSQL) ───
# Railway auto-provides DATABASE_URL when you add PostgreSQL service
# Example: postgresql://postgres:password@host:5432/railway
# DATABASE_URL=postgresql://postgres:password@localhost:5432/storeos

# NextAuth
NEXTAUTH_SECRET=your-secret-here-change-this
NEXTAUTH_URL=http://localhost:3000
